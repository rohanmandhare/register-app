pipeline{
	agent {label 'Jenkins-Agent'}
  	tools{
	  jdk 'Java17'
	  maven 'Maven3'
    	}
	  stages{
		  stage("Cleanup Workspace"){
	    	  steps{ cleanWS()
			}
		}
	     stage("Checkout from SCM"){
		  	  steps{
			      git branch: 'main', credintialsId: 'github', url: 'https://https://github.com/rohanmandhare/register-app'
		   	}
		}

		    stage("Build Application"){
			    steps{
				    sh "mvn clean package"
		    	}
		
		  }

	    	stage("Test Application"){
		    	steps{
				    sh "mvn test"
		    	}
	  	}
	
      }
}





